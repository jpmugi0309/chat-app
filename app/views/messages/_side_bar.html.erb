<div class="sidebar_header">
  <div class="sidebar_user_name">
    <%= link_to current_user.name, edit_user_path(current_user) %>
  </div>
  <div class="sidebar_room_new">
    <%= link_to "チャットを作成する", new_room_path %>
  </div>
</div>

<div class="sidebar_rooms">
  <% current_user.rooms.each do |room| %>
    <div class="sidebar_room">
      <div class="sidebar_room_name">
        <%= link_to room.name, room_messages_path(room) %>
      </div>
    </div>
  <% end %>
</div>