<div class="chat_header">
  <div class="chat_left_header">
    <div class="chat_title">
      <p>hogehuga</p>
    </div>
  </div>
  <div class="chat_right_header">
    <div class="chat_end_button">
      <a href="#">チャットを終了する</a>
    </div>
  </div>
</div>

<div class="chat_messages">
  <%= render partial: 'message', collection: @messages %>
</div>

<%= form_with model: [@room, @message], html: {class: "chat_footer"}, local: true do |f|%>
  <div class="chat_input">
    <%= f.text_field :content, class: 'chat_input_message', placeholder: 'type a message' %>
    <label class="form-image">
      <span class="image-file">画像</span>
      <%= f.file_field :image, class: 'hidden' %>
    </label>
  </div>
  <%= f.submit '送信', class: 'chat_send_button' %>
<% end %>